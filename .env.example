# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/worldcup

# ── Football data provider ─────────────────────────────────────────────
# Options: espn | mock | api_football
FOOTBALL_API_PROVIDER=espn

# Only needed if FOOTBALL_API_PROVIDER=api_football:
# FOOTBALL_API_KEY=your_rapidapi_key_here
# FOOTBALL_API_HOST=v3.football.api-sports.io

# ── Application ────────────────────────────────────────────────────────
# Options: development | production
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend (set in Vercel dashboard for production) ──────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
